       <string>&lt;html&gt;
&lt;h1 style='color:#569cd6; font-family:monospace; margin:0;'&gt;HARDWARE TRACKER&lt;/h1&gt;
&lt;p style='color:#3c3c3c; font-family:monospace; font-size:10px; margin:0;'&gt;────────────────────────────────────────&lt;/p&gt;
&lt;p style='color:#8b949e; font-family:monospace; font-size:9px; margin:2px 0 0 0;'&gt;real-time system monitor &lt;a href='https://github.com/SyKaya' style='color:#569cd6; text-decoration:none;'&gt;[SyKaya]&lt;/a&gt;&lt;/p&gt;
&lt;/html&gt;</string>
