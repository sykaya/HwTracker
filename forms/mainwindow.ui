  <property name="styleSheet">
   <string>
   QMainWindow {
       background-color: #1e1e1e;
   }
   QWidget#centralwidget {
       background-color: #252526;
   }
   QGroupBox {
       font-family: monospace;
       font-size: 11px;
       color: #cccccc;
       border: 1px solid #3c3c3c;
       border-radius: 4px;
       margin-top: 6;
       background-color: #1e1e1e;
   }
   QGroupBox::title {
       subcontrol-origin: margin;
       left: 12px;
       top: -4px;
       padding: 0 4px;
       color: #569cd6;
       background-color: #1e1e1e;
   }
   QPushButton {
       background-color: #3c3c3c;
       border: none;
       color: #f0f0f0;
       font-family: monospace;
       font-size: 11px;
       padding: 6px 14px;
   }
   QPushButton#btnRefresh, QPushButton#btnNetworkTest {
       border-radius: 8px;
   }
   QPushButton:hover {
       background-color: #505050;
   }
   QProgressBar {
       background-color: #2d2d30;
       border: none;
       border-radius: 6px;
       text-align: center;
       color: #cccccc;
       font-size: 9px;
       height: 20px;
   }
   QProgressBar::chunk {
       background-color: #569cd6;
       border-radius: 6px;
   }
   QLabel {
       color: #bbbbbb;
       font-family: monospace;
       font-size: 10px;
   }
   QLabel#lblTitle {
       color: #569cd6;
       font-size: 13px;
       padding: 6px;
   }
   QLabel#lblTitle a {
       color: #569cd6;
       text-decoration: none;
   }
   QLabel#lblTitle a:hover {
       color: #9cdcfe;
       text-decoration: underline;
   }
   QListWidget {
       background-color: #1e1e1e;
       border: 1px solid #3c3c3c;
       border-radius: 4px;
       color: #cccccc;
       font-family: monospace;
       font-size: 10px;
       outline: none;
   }
   QListWidget::item:selected {
       background-color: #3c3c3c;
       color: #ffffff;
   }
   QMenuBar {
       background-color: #1e1e1e;
       color: #bbbbbb;
       border-bottom: 1px solid #3c3c3c;
   }
   QMenuBar::item:selected {
       background-color: #3c3c3c;
       color: #ffffff;
   }
   QMenu {
       background-color: #1e1e1e;
       border: 1px solid #3c3c3c;
       color: #cccccc;
   }
   QMenu::item:selected {
       background-color: #3c3c3c;
       color: #ffffff;
   }
    }
   </string>
